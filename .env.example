# GoldRush API key — sign up free at https://goldrush.dev/platform
# Starts with `cqt_` (foundational) or `ckey_` (legacy). 25,000 credits on the 14-day trial.
GOLDRUSH_API_KEY=cqt_replace_me

# (Optional) OpenAI API key — enables the AI-generated wallet briefing.
# Without this, the /api/wallet/[address]/ai-summary endpoint returns a
# deterministic fallback summary (still useful, just not LLM-written).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (Optional) Public site URL — used to render OpenGraph images and server-to-
# server fetches from the ai-summary / og-image handlers. Vercel auto-sets
# VERCEL_URL which is used as fallback.
# NEXT_PUBLIC_SITE_URL=https://halo.vercel.app
